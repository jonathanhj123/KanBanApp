# Copy to .env (git-ignored) and fill in real values.

# From Google Cloud console (the GoogleOAuthProject client can be reused)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Any long random string — signs the session cookie. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=change-me

# Neon connection strings (dev database + a separate one for tests)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
TEST_DATABASE_URL=postgresql://user:pass@host/test_dbname?sslmode=require

# Must EXACTLY match an authorized redirect URI in the Google console.
# Real flow (through the Vite proxy): http://localhost:5173/auth/callback
# Backend-only testing (Task 4.4):   http://localhost:8001/auth/callback
REDIRECT_URI=http://localhost:5173/auth/callback
